# Copy this file to .env in the project root and fill in what you have.
# Sentinel runs fully functional in degraded mode with everything below left blank —
# threat intel cards show "Not Configured" and AI summaries use the rule-based fallback.

# --- General ---
APP_NAME=Sentinel
ENV=development
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=sqlite:///sentinel.db

# --- Storage ---
UPLOAD_DIRECTORY=uploads/
REPORT_DIRECTORY=reports/
LOG_DIRECTORY=logs/
MAX_UPLOAD_SIZE_MB=100

# --- Threat Intelligence (optional) ---
VT_API_KEY=
MALWAREBAZAAR_API_KEY=
TI_REQUEST_TIMEOUT_SECONDS=15
TI_CACHE_DURATION_MINUTES=60

# --- AI (optional) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
